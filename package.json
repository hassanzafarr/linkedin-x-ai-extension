{
  "type": "module",
  "name": "engageflow-extension",
  "version": "1.0.0",
  "description": "AI reply suggestions, feed scoring, and post drafting for LinkedIn and X",
  "private": true,
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && vite build --config vite.content.config.js",
    "preview": "echo 'Load dist/ as unpacked extension at chrome://extensions'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:eval": "vitest run tests/unit/eval.test.js",
    "test:all": "npm run test && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^4.1.7",
    "autoprefixer": "^10.4.21",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "vite": "^6.3.5",
    "vitest": "^4.1.7"
  }
}
